{
  "name": "drift",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "drift": "bun run src/cli/main.ts",
    "drift:run": "bun run src/cli/main.ts run",
    "drift:plan": "bun run src/cli/main.ts plan",
    "drift:commit": "bun run src/cli/main.ts commit",
    "drift:edit": "bun run src/cli/main.ts edit",
    "drift:new": "bun run src/cli/main.ts new",
    "drift:init": "bun run src/cli/main.ts init",
    "drift:assemble": "bun run src/cli/main.ts assemble",
    "server": "bun run src/server/index.ts",
    "ui": "bun run src/ui/index.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:ast-grep": "ast-grep scan --config .ast-grep/sgconfig.yml --error",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "bun run lint:ast-grep && bun run lint && bun run format:check && bun run typecheck"
  },
  "dependencies": {
    "@effect/language-service": "^0.73.1",
    "effect": "^3.19.16"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260210.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0"
  }
}
